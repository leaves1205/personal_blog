---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;

const pathname = Astro.url.pathname;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">

      <!-- Nav -->
      <header class="sticky top-0 z-10 border-b border-slate-200 bg-white/80 backdrop-blur-sm">
        <nav class="mx-auto flex max-w-2xl items-center justify-between px-6 py-4">
          <a href="/" class="font-semibold text-slate-900 tracking-tight hover:text-indigo-600 transition-colors">
            Yunqi's Notes
          </a>
          <div class="flex items-center gap-6 text-sm">
            <a
              href="/"
              class={`transition-colors ${pathname === '/' ? 'text-indigo-600 font-medium' : 'text-slate-500 hover:text-slate-900'}`}
            >
              首页
            </a>
            <a
              href="/blog"
              class={`transition-colors ${pathname.startsWith('/blog') ? 'text-indigo-600 font-medium' : 'text-slate-500 hover:text-slate-900'}`}
            >
              文章
            </a>
          </div>
        </nav>
      </header>

      <!-- Main -->
      <main class="mx-auto w-full max-w-2xl flex-1 px-6 py-12">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="border-t border-slate-200">
        <div class="mx-auto max-w-2xl px-6 py-6 text-center text-sm text-slate-400">
          © {new Date().getFullYear()} Yunqi's Notes
        </div>
      </footer>

    </div>
  </body>
</html>
