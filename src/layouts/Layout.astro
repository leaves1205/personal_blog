---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
}
const { title } = Astro.props;
const pathname = Astro.url.pathname;
const user = Astro.locals.user;

const allPosts = await getCollection('blog', ({ data }) => data.draft !== true);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>

    <!-- ── Mobile top bar ── -->
    <header class="lg:hidden fixed top-0 inset-x-0 z-50 flex items-center justify-between px-4 py-3 bg-gradient-to-r from-indigo-950 to-purple-950 shadow-md">
      <a href="/" class="font-bold text-white text-lg tracking-tight">OpenIT</a>
      <button id="menu-btn" aria-label="打开菜单" class="text-white p-1.5 rounded-lg hover:bg-white/10 transition-colors">
        <svg id="icon-open"  width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
          <line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24" class="hidden">
          <line x1="18" y1="6"  x2="6"  y2="18"/><line x1="6"  y1="6"  x2="18" y2="18"/>
        </svg>
      </button>
    </header>

    <!-- ── Mobile overlay ── -->
    <div id="overlay" class="lg:hidden fixed inset-0 z-40 bg-black/60 hidden" aria-hidden="true"></div>

    <div class="flex min-h-screen">

      <!-- ══ SIDEBAR ══ -->
      <aside id="sidebar" class="
        fixed inset-y-0 left-0 z-40 w-72
        flex flex-col
        bg-gradient-to-b from-indigo-950 via-indigo-900 to-purple-950
        overflow-y-auto
        transition-transform duration-300
        -translate-x-full lg:translate-x-0
      ">
        <!-- Brand -->
        <div class="px-6 pt-8 pb-6 border-b border-white/10">
          <a href="/" class="block font-bold text-xl text-white tracking-tight hover:text-indigo-200 transition-colors">
            OpenIT
          </a>
          <p class="mt-1 text-xs text-indigo-400">Free IT Knowledge · Open to All</p>
        </div>

        <!-- Nav links -->
        <nav class="px-4 pt-5 pb-4 border-b border-white/10 space-y-1">
          <a href="/dashboard" class={`sidebar-link ${pathname === '/dashboard' ? 'active' : ''}`}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            Dashboard
          </a>
          <a href="/" class={`sidebar-link ${pathname === '/' ? 'active' : ''}`}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            首页
          </a>
          <a href="/blog" class={`sidebar-link ${pathname === '/blog' ? 'active' : ''}`}>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            所有文章
          </a>
        </nav>

        <!-- Article list -->
        <div class="px-4 pt-5 pb-8 flex-1">
          <p class="px-2 mb-3 text-[11px] font-semibold uppercase tracking-widest text-indigo-400">
            文章列表
          </p>
          {allPosts.length === 0 ? (
            <p class="px-2 text-sm text-indigo-500 italic">暂无文章</p>
          ) : (
            <ol class="space-y-0.5">
              {allPosts.map((post, i) => {
                const isActive = pathname === `/blog/${post.id}`;
                return (
                  <li>
                    <a
                      href={`/blog/${post.id}`}
                      class={`group flex items-start gap-2.5 px-2 py-2 rounded-lg text-sm transition-colors ${
                        isActive
                          ? 'bg-white/15 text-white'
                          : 'text-indigo-200 hover:bg-white/10 hover:text-white'
                      }`}
                    >
                      <span class={`shrink-0 mt-0.5 w-5 h-5 rounded-full flex items-center justify-center text-[11px] font-bold ${
                        isActive ? 'bg-indigo-400 text-white' : 'bg-white/10 text-indigo-400 group-hover:bg-indigo-500 group-hover:text-white'
                      } transition-colors`}>
                        {i + 1}
                      </span>
                      <span class="leading-snug line-clamp-2">{post.data.title}</span>
                    </a>
                  </li>
                );
              })}
            </ol>
          )}
        </div>

        <!-- Admin link -->
        {user?.role === 'admin' && (
          <div class="px-4 pb-3">
            <a href="/admin" class={`sidebar-link ${pathname.startsWith('/admin') ? 'active' : ''} text-red-300 hover:text-red-200`}>
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              Admin
            </a>
          </div>
        )}

        <!-- Footer in sidebar -->
        <div class="px-6 py-4 border-t border-white/10 space-y-2">
          <p class="text-xs text-indigo-400">
            你好，<span class="text-white font-medium">{user?.username}</span>
          </p>
          <form method="POST" action="/api/logout">
            <button type="submit" class="text-xs text-indigo-500 hover:text-red-400 transition-colors">
              退出登录
            </button>
          </form>
          <p class="text-xs text-indigo-600">© {new Date().getFullYear()} OpenIT</p>
        </div>
      </aside>

      <!-- ══ MAIN ══ -->
      <div class="flex-1 lg:ml-72 flex flex-col min-h-screen">
        <main class="flex-1 pt-14 lg:pt-0">
          <div class="w-full px-8 py-10">
            <slot />
          </div>
        </main>
      </div>

    </div>

    <script>
      const btn     = document.getElementById('menu-btn');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('overlay');
      const iconOpen  = document.getElementById('icon-open');
      const iconClose = document.getElementById('icon-close');

      function open() {
        sidebar?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
      function close() {
        sidebar?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      }

      btn?.addEventListener('click', () =>
        sidebar?.classList.contains('-translate-x-full') ? open() : close()
      );
      overlay?.addEventListener('click', close);
    </script>

  </body>
</html>

<style>
  html, body { margin: 0; background: #f8fafc; }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    font-size: 0.875rem;
    color: #a5b4fc;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }
  .sidebar-link:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }
  .sidebar-link.active {
    background: rgba(255,255,255,0.15);
    color: white;
    font-weight: 500;
  }

  /* scrollbar in sidebar */
  #sidebar::-webkit-scrollbar { width: 4px; }
  #sidebar::-webkit-scrollbar-track { background: transparent; }
  #sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }
</style>
