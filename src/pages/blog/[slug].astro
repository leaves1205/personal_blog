---
import Layout from '../../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import { env } from 'cloudflare:workers';

const { slug } = Astro.params;
const post = await getEntry('blog', slug!);

if (!post || post.data.draft) {
  return Astro.redirect('/blog');
}

const { Content } = await render(post);

const user = Astro.locals.user;
const isAdmin = user?.role === 'admin';

type Comment = { id: number; username: string; content: string; created_at: string };
const { results: comments } = await env.learning_blog_db
  .prepare('SELECT id, username, content, created_at FROM comments WHERE post_slug = ? ORDER BY created_at ASC')
  .bind(slug)
  .all<Comment>();

const tagColors: Record<string, string> = {
  '全栈':   'bg-blue-100 text-blue-700',
  'AI':     'bg-violet-100 text-violet-700',
  '算法':   'bg-emerald-100 text-emerald-700',
  '随笔':   'bg-amber-100 text-amber-700',
  '实践':   'bg-rose-100 text-rose-700',
};
function tagColor(tag: string) {
  return tagColors[tag] ?? 'bg-slate-100 text-slate-600';
}
---

<Layout title={`${post.data.title} | OpenIT`}>

  <!-- Back -->
  <a
    href="/blog"
    class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-indigo-600 transition-colors mb-8"
  >
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
      <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
    </svg>
    返回文章列表
  </a>

  <article>
    <!-- Header -->
    <header class="mb-10">
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {post.data.tags.map(tag => (
            <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${tagColor(tag)}`}>
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight mb-3 text-center">
        {post.data.title}
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-4">{post.data.description}</p>

      <div class="flex items-center gap-3">
        <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold">
          Y
        </div>
        <span class="text-sm text-slate-500">Jenny</span>
        <span class="text-slate-300">·</span>
        <time class="text-sm text-slate-400">
          {post.data.date.toISOString().slice(0, 10)}
        </time>
      </div>

      <div class="mt-6 h-px bg-gradient-to-r from-indigo-200 via-purple-200 to-transparent"></div>
    </header>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>
  </article>

  <!-- ══ 评论区 ══ -->
  <section class="mt-16 pt-10 border-t border-slate-200">
    <h2 class="text-lg font-bold text-slate-800 mb-6 flex items-center gap-2">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      评论 <span class="text-slate-400 font-normal text-sm">({comments.length})</span>
    </h2>

    <!-- 评论列表 -->
    {comments.length === 0 ? (
      <p class="text-slate-400 text-sm py-6 text-center">还没有评论，来发表第一条吧！</p>
    ) : (
      <div class="space-y-4 mb-10">
        {comments.map(c => (
          <div class="flex gap-3 group">
            <div class="shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold">
              {c.username[0].toUpperCase()}
            </div>
            <div class="flex-1 bg-slate-50 rounded-xl px-4 py-3">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-semibold text-slate-700">{c.username}</span>
                <div class="flex items-center gap-3">
                  <time class="text-xs text-slate-400">{c.created_at.slice(0, 16).replace('T', ' ')}</time>
                  {isAdmin && (
                    <form method="POST" action="/api/admin/delete-comment">
                      <input type="hidden" name="comment_id" value={c.id} />
                      <input type="hidden" name="post_slug" value={slug} />
                      <button type="submit" class="text-xs text-red-400 hover:text-red-600 opacity-0 group-hover:opacity-100 transition-opacity">
                        删除
                      </button>
                    </form>
                  )}
                </div>
              </div>
              <p class="text-sm text-slate-600 leading-relaxed whitespace-pre-wrap">{c.content}</p>
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- 发表评论 -->
    <form method="POST" action="/api/comments/add" class="space-y-3">
      <input type="hidden" name="post_slug" value={slug} />
      <div>
        <label class="block text-sm font-medium text-slate-600 mb-1.5">
          以 <span class="text-indigo-600 font-semibold">{user.username}</span> 身份发表评论
        </label>
        <textarea
          name="content"
          required
          maxlength="1000"
          rows="3"
          placeholder="写下你的想法..."
          class="w-full border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 placeholder-slate-300 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-transparent resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="inline-flex items-center gap-1.5 bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-sm font-semibold px-5 py-2 rounded-xl hover:opacity-90 transition-opacity"
      >
        发表评论
      </button>
    </form>
  </section>

</Layout>
