---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const tagColors: Record<string, string> = {
  '全栈':   'bg-blue-100 text-blue-700',
  'AI':     'bg-violet-100 text-violet-700',
  '算法':   'bg-emerald-100 text-emerald-700',
  '随笔':   'bg-amber-100 text-amber-700',
  '实践':   'bg-rose-100 text-rose-700',
};
function tagColor(tag: string) {
  return tagColors[tag] ?? 'bg-slate-100 text-slate-600';
}
---

<Layout title={`${post.data.title} | Jenny's Notes`}>

  <!-- Back -->
  <a
    href="/blog"
    class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-indigo-600 transition-colors mb-8"
  >
    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
      <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
    </svg>
    返回文章列表
  </a>

  <article>
    <!-- Header -->
    <header class="mb-10">
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {post.data.tags.map(tag => (
            <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${tagColor(tag)}`}>
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight mb-3 text-center">
        {post.data.title}
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mb-4">{post.data.description}</p>

      <div class="flex items-center gap-3">
        <div class="w-7 h-7 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold">
          Y
        </div>
        <span class="text-sm text-slate-500">Jenny</span>
        <span class="text-slate-300">·</span>
        <time class="text-sm text-slate-400">
          {post.data.date.toISOString().slice(0, 10)}
        </time>
      </div>

      <div class="mt-6 h-px bg-gradient-to-r from-indigo-200 via-purple-200 to-transparent"></div>
    </header>

    <!-- Content -->
    <div class="prose">
      <Content />
    </div>
  </article>

</Layout>
