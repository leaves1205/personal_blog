---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.draft !== true);

posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Blog | Yunqi's Notes">
  <h1 class="mb-8 text-3xl font-bold">Blog</h1>

  <div class="space-y-6">
    {posts.map((post) => (
      <article class="rounded-2xl border border-zinc-200 p-5">
        <h2 class="text-xl font-semibold">
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </h2>
        <p class="mt-2 text-sm text-zinc-500">
          {post.data.date.toISOString().slice(0, 10)}
        </p>
        <p class="mt-3 text-zinc-700">{post.data.description}</p>

        <div class="mt-4 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="rounded-full bg-zinc-100 px-3 py-1 text-xs text-zinc-700">
              #{tag}
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>
</Layout>