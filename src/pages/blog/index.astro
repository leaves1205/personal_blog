---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.draft !== true);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="文章 | Yunqi's Notes">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-slate-900">文章</h1>
    <p class="mt-2 text-slate-500">共 {posts.length} 篇</p>
  </div>

  {posts.length === 0 ? (
    <p class="text-slate-400 text-center py-16">还没有文章，敬请期待。</p>
  ) : (
    <div class="space-y-3">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group block rounded-xl border border-slate-200 bg-white p-5 hover:border-indigo-300 hover:shadow-sm transition-all"
        >
          <div class="flex items-start justify-between gap-4">
            <h2 class="font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">
              {post.data.title}
            </h2>
            <time class="shrink-0 text-sm text-slate-400 mt-0.5">
              {post.data.date.toISOString().slice(0, 10)}
            </time>
          </div>
          <p class="mt-2 text-sm text-slate-500 line-clamp-2">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs text-slate-600">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  )}
</Layout>
