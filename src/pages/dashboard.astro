---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const user = Astro.locals.user;
const posts = await getCollection('blog', ({ data }) => data.draft !== true);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagColors: Record<string, string> = {
  'full-stack':  'bg-blue-100 text-blue-700',
  'AI':    'bg-violet-100 text-violet-700',
  'algorithm':  'bg-emerald-100 text-emerald-700',
};
function tagColor(tag: string) {
  return tagColors[tag] ?? 'bg-slate-100 text-slate-600';
}

// 统计每个 tag 的文章数
const tagCount: Record<string, number> = {};
posts.forEach(p => p.data.tags.forEach(t => { tagCount[t] = (tagCount[t] ?? 0) + 1; }));
---

<Layout title="Dashboard | Jenny's Notes">

  <!-- 欢迎栏 -->
  <div class="mb-10 pb-8 border-b border-slate-200">
    <p class="text-sm text-indigo-500 font-medium mb-1">欢迎回来</p>
    <h1 class="text-3xl font-extrabold text-slate-900">{user?.username} 的笔记</h1>
    <p class="mt-2 text-slate-500 text-sm">共 {posts.length} 篇文章</p>

    <!-- Tag 统计 -->
    <div class="flex flex-wrap gap-2 mt-4">
      {Object.entries(tagCount).map(([tag, count]) => (
        <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium ${tagColor(tag)}`}>
          {tag}
          <span class="opacity-60">{count}</span>
        </span>
      ))}
    </div>
  </div>

  <!-- 文章列表 -->
  {posts.length === 0 ? (
    <div class="text-center py-20 text-slate-400">
      <svg class="mx-auto mb-4 opacity-30" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      <p>还没有文章，开始写第一篇吧！</p>
    </div>
  ) : (
    <div class="space-y-3">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex gap-4 bg-white rounded-2xl border border-slate-200 p-5 hover:border-indigo-300 hover:shadow-md transition-all"
        >
          <div class="shrink-0 pt-0.5">
            <span class="w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-sm font-bold shadow-sm">
              {i + 1}
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3">
              <h2 class="font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">
                {post.data.title}
              </h2>
              <time class="shrink-0 text-xs text-slate-400 mt-0.5">
                {post.data.date.toISOString().slice(0, 10)}
              </time>
            </div>
            <p class="mt-1.5 text-sm text-slate-500 line-clamp-2">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {post.data.tags.map(tag => (
                  <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${tagColor(tag)}`}>
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  )}

</Layout>
