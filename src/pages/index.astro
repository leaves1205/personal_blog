---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.draft !== true);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 3);
---

<Layout title="Yunqi's Notes">
  <!-- Hero -->
  <section class="pb-12 border-b border-slate-200">
    <p class="text-xs font-medium uppercase tracking-widest text-indigo-500 mb-4">Personal Blog</p>
    <h1 class="text-4xl font-bold text-slate-900 leading-tight mb-4">
      学习摘要 &amp; 技术笔记
    </h1>
    <p class="text-lg text-slate-500 leading-relaxed max-w-lg">
      记录前端、AI、算法和项目实践中的学习总结，沉淀思考，持续成长。
    </p>
    <a
      href="/blog"
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-700 transition-colors"
    >
      浏览所有文章
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </section>

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="pt-12">
      <h2 class="text-sm font-medium uppercase tracking-widest text-slate-400 mb-6">最新文章</h2>
      <div class="space-y-4">
        {recentPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex items-start justify-between gap-4 rounded-xl p-4 -mx-4 hover:bg-slate-100 transition-colors"
          >
            <div class="min-w-0">
              <h3 class="font-medium text-slate-900 group-hover:text-indigo-600 transition-colors truncate">
                {post.data.title}
              </h3>
              <p class="mt-1 text-sm text-slate-500 line-clamp-1">{post.data.description}</p>
            </div>
            <time class="shrink-0 text-sm text-slate-400 mt-0.5">
              {post.data.date.toISOString().slice(0, 10)}
            </time>
          </a>
        ))}
      </div>
    </section>
  )}
</Layout>
