---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home | Yunqi's Notes">
  <section class="space-y-4">
    <p class="text-sm uppercase tracking-widest text-zinc-500">Personal Blog</p>
    <h1 class="text-4xl font-bold">学习摘要 / 技术笔记</h1>
    <p class="text-zinc-600">
      这里记录我在前端、AI、算法和项目实践中的学习总结。
    </p>

    <div class="pt-4">
      <a
        href="/blog"
        class="inline-block rounded-xl bg-zinc-900 px-5 py-3 text-white"
      >
        查看文章
      </a>
    </div>
  </section>
</Layout>