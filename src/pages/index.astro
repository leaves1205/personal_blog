---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.draft !== true);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, 5);

const tagColors: Record<string, string> = {
  'full-stack':   'bg-blue-100 text-blue-700',
  'AI':     'bg-violet-100 text-violet-700',
  'algorithm':   'bg-emerald-100 text-emerald-700',
};
function tagColor(tag: string) {
  return tagColors[tag] ?? 'bg-slate-100 text-slate-600';
}
---

<Layout title="Jenny's Notes">

  <!-- Hero -->
  <section class="pb-10 mb-10 border-b border-slate-200">
    <div class="flex justify-center mb-5">
      <div class="inline-flex items-center gap-2 bg-indigo-50 text-indigo-600 text-xs font-semibold px-3 py-1 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
        Personal Blog
      </div>
    </div>
    <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight text-slate-900 mb-4 text-center">
      学习摘要
      <span class="block mt-1 bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent">
        技术笔记
      </span>
    </h1>
    <p class="text-lg leading-relaxed max-w-md">
      notes for full-stack, algorithm...
    </p>

    <!-- Topic tags -->
    <div class="flex flex-wrap gap-2 mt-6">
      {(['full-stack', 'AI', 'algorithm'] as const).map(tag => (
        <span class={`px-3 py-1 rounded-full text-sm font-medium ${tagColor(tag)}`}>
          {tag}
        </span>
      ))}
    </div>

    <a
      href="/blog"
      class="mt-8 inline-flex items-center gap-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white text-sm font-semibold px-5 py-2.5 rounded-xl shadow-md hover:shadow-lg hover:from-indigo-700 hover:to-purple-700 transition-all"
    >
      浏览所有文章
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" viewBox="0 0 24 24">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </section>

  <!-- Recent posts -->
  {recentPosts.length > 0 && (
    <section>
      <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-5">最新文章</h2>
      <div class="space-y-3">
        {recentPosts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class="group flex items-start gap-4 p-4 -mx-4 rounded-xl hover:bg-white hover:shadow-sm border border-transparent hover:border-slate-200 transition-all"
          >
            <span class="shrink-0 mt-0.5 w-7 h-7 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-white text-xs font-bold shadow-sm">
              {i + 1}
            </span>
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors">
                {post.data.title}
              </h3>
              <p class="mt-0.5 text-sm text-slate-500 truncate">{post.data.description}</p>
            </div>
            <time class="shrink-0 text-xs text-slate-400 mt-1">
              {post.data.date.toISOString().slice(0, 10)}
            </time>
          </a>
        ))}
      </div>
    </section>
  )}

</Layout>
